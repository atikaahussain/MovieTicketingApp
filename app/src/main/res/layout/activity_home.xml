<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Date Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_date"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btnToday"
            android:layout_width="80dp"
            android:layout_height="36dp"
            android:text="@string/today"
            android:textSize="11sp"
            android:backgroundTint="@color/red"
            android:textColor="@color/white"
            android:layout_marginEnd="8dp"/>

    </LinearLayout>

    <!-- Now Showing Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/now_showing"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Movies List Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Movie 1: The Dark Knight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_dark_knight"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/movie_poster_1"
                    android:scaleType="centerCrop"
                    android:contentDescription="The Dark Knight Poster"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie_dark_knight"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action / 152 min"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:id="@+id/btnTrailer1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Play Trailer"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBookSeats1"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/book_seats"
                    android:textSize="12sp"
                    android:backgroundTint="@color/red"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Movie 2: Inception -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_inception"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/movie_poster_2"
                    android:scaleType="centerCrop"
                    android:contentDescription="Inception Poster"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie_inception"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi / 148 min"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:id="@+id/btnTrailer2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Play Trailer"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBookSeats2"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/book_seats"
                    android:textSize="12sp"
                    android:backgroundTint="@color/red"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Movie 3: Interstellar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_interstellar"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/movie_poster_3"
                    android:scaleType="centerCrop"
                    android:contentDescription="Interstellar Poster"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie_interstellar"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi / 169 min"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:id="@+id/btnTrailer3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Play Trailer"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBookSeats3"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/book_seats"
                    android:textSize="12sp"
                    android:backgroundTint="@color/red"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Movie 4: The Shawshank Redemption -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_shawshank"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/movie_poster_4"
                    android:scaleType="centerCrop"
                    android:contentDescription="The Shawshank Redemption Poster"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie_shawshank"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drama / 142 min"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray"
                        android:layout_marginTop="4dp"/>

                    <ImageView
                        android:id="@+id/btnTrailer4"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Play Trailer"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBookSeats4"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/book_seats"
                    android:textSize="12sp"
                    android:backgroundTint="@color/red"
                    android:textColor="@color/white"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>